# Copy this to .env and fill in values for local development
# For Docker, environment vars are set directly in docker-compose.yml

# Local dev — uses host-mapped ports from docker-compose infra services
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/research_platform
REDIS_URL=redis://localhost:6380
RABBITMQ_URL=amqp://guest:guest@localhost:5673/

# Generate a secure random key for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
